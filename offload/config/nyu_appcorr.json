{
    "model_name": "dinov3_depther",
    "dataset_name": "nyu_depth",
    "dataset_kwargs": {"data_root": "~/data/NYU"},
    "exp_id": "nyu_appcorr",
    "batch_size": 1,
    "image_shape": [768, 768, 3],
    "patch_size": [16, 16],
    "input_profile_name": "dinov3_nyu_synthmix_dpt",
    "input_profile_kwargs": {"depther_use_tta": true},
    "scheduler_policy_name": "NYUApproxCorrect",
    "transmission_policy_name": "ProgressiveLaplacian",
    "transmission_kwargs": {
        "pyramid_levels": [2, 0],
        "grouping_strategy": "grid",
        "num_groups": 1,
        "compression_level": 1,
        "preserve_input_shape": true
    },
    "appcorr_kwargs": {
        "generated_from_client": true,
        "token_keep_thres": 0.0001,
        "mobile_pscore": "residual_energy",
        "mobile_pscore_weight": 1.0,
        "server_pscore": "patch_pseudo_attn_prob_layermean",
        "server_pscore_weight": 1.0,
        "pscore_fusion": "geo_mean",
        "sdpa_query_bucket_size": 64
    },
    "device": "cuda:1"
}
